# -------------------------------------
# DATABASE (from Supabase)
# -------------------------------------
# Go to your Supabase project -> Project Settings -> Database -> Connection string
# These are optional — the app runs in demo mode without them
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Prisma connection strings (required only if using Prisma CLI)
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# -------------------------------------
# AUTHENTICATION (NextAuth v5)
# -------------------------------------
# A secret string used to sign tokens. Generate one: https://generate-secret.vercel.app/
AUTH_SECRET=""

# Google OAuth credentials from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -------------------------------------
# APP
# -------------------------------------
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# -------------------------------------
# PAYMENTS (Stripe) — optional, features disabled if not set
# -------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# -------------------------------------
# EMAIL (Resend) — optional, features disabled if not set
# -------------------------------------
RESEND_API_KEY=""
FROM_EMAIL="noreply@outbackconnections.com.au"
